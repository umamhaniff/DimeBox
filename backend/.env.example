# DimeBox - Environment Configurations

# 1. Database Connection URL
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
# For Supabase, use the connection string provided in Project Settings -> Database.
# Note: For Serverless environments, prefer using the Connection Pooler (Port 6543) instead of direct connection.
DATABASE_URL=postgresql://postgres.your-project-id:your-db-password@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# 2. Supabase JWT Secret Key
# Retrieve this from: Supabase Dashboard -> Project Settings -> API -> JWT Settings -> JWT Secret
# This secret is used to statelessly verify incoming user JWT tokens in FastAPI.
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_key_here
